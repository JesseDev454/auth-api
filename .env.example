PORT=3000
NODE_ENV=development

# Preferred for hosted environments such as Render.
# If DATABASE_URL is set, it overrides the individual DB_* variables below.
DATABASE_URL=

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=authentication_api
DB_USER=postgres
DB_PASSWORD=postgres

JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_secret

APP_BASE_URL=http://localhost:3000
LOG_LEVEL=info
